# Blobverse Game Server — Environment Variables

# Server
PORT=3000
NODE_ENV=development

# Game Settings
MAX_PLAYERS_PER_ROOM=30
AI_FILL_RATIO=0.6
TICK_RATE=20

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5174,https://blobverse.game

# Optional: External services
# REDIS_URL=redis://localhost:6379
# DATABASE_URL=postgresql://...
